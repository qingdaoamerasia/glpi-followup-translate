# GLPI Followup Translate - Configuration Template
# Copy this file to config.yaml and fill in your actual values.

glpi:
  # GLPI API base URL
  api_url: "http://your-glpi-server/api.php/v2.3"

  # Authentication method: "oauth2_password" or "app_token"
  # - oauth2_password: OAuth2 Password Flow (recommended for services/daemons)
  # - app_token: GLPI App-Token + User-Token (standard GLPI API auth)
  auth_method: "oauth2_password"

  # OAuth2 credentials (Client ID + Client Secret from GLPI OAuth2 settings)
  client_id: "your_client_id_here"
  client_secret: "your_client_secret_here"

  # GLPI user credentials (required for oauth2_password flow)
  # Username: the GLPI login username
  # Password: the GLPI login password
  username: "your_glpi_username"
  password: "your_glpi_password"

ollama:
  # Ollama API base URL
  api_url: "http://localhost:11434"

  # Model name for translation
  model: "kaelri/hy-mt2:1.8b"

  # Ollama request timeout in seconds
  timeout: 60

# Polling settings
polling:
  # Interval in seconds between each check for new followups
  interval: 60

# Translation settings
translation:
  # Prefix added to translated followup text
  prefix: "[AUTO-TRANSLATED]"

  # Minimum text length (plain text, after stripping HTML) to trigger translation.
  # Set to 0 to translate any text regardless of length.
  min_text_length: 0

  # Supported language pairs
  # zh-cn -> en, en -> zh-cn
  source_languages:
    - "zh-cn"
    - "zh"
    - "en"
  target_language:
    zh-cn: "en"
    zh: "en"
    en: "zh-cn"

# Logging
logging:
  level: "INFO"  # DEBUG, INFO, WARNING, ERROR
  file: "glpi-translate.log"
